# Example environment variables for LiraPro
# Copy this to .env and fill values when running locally or on Replit (DO NOT commit .env to git)

# Server
PORT=5000
ADMIN_TOKEN=change_me_securely
REPLIT_DOMAINS=
LIRAPRO_ZIP_PATH=

# Third-party APIs
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Database (Drizzle/Supabase) configuration examples
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Notes:
# - Set REPLIT_DOMAINS to your Replit public domain (e.g. myproj.username.repl.co) to allow CORS in production.
# - LIRAPRO_ZIP_PATH can be an absolute path (e.g. /home/runner/workspace/lirapro_final.zip) or a
#   relative path inside the repo (e.g. ./lirapro-project.zip). If empty, the server will try common filenames.
